{#
    Media brick — the four Combat UI media blocks plus a linked banner:
    figure, full-width, banner, media card and overlay card. The frontend
    delegates to the @CombatUICore media templates.

    Editing split: the dialog holds settings only (style, aspect ratio,
    media type and layout); all content — the chosen media (image or video),
    caption, eyebrow, title, body copy, media link and actions — is edited
    inline on the page.
#}
{% set style = opendxp_select('style').getData()|default('') %}
{% set style = style ?: 'figure' %}
{% set ratio = opendxp_select('ratio').getData()|default(null) %}
{% set width = opendxp_select('width').getData()|default('') %}
{% set align = opendxp_select('align').getData()|default('') %}
{% set media_type = opendxp_select('media_type').getData()|default('') %}
{% set use_video = media_type == 'video' %}
{% set image = opendxp_image('image') %}
{% set video = opendxp_video('video') %}
{% set caption_editable = opendxp_input('caption', {placeholder: 'Caption (optional)'}) %}
{% set eyebrow_editable = opendxp_input('eyebrow', {placeholder: 'Eyebrow (optional)'}) %}
{% set title_editable = opendxp_input('title', {placeholder: 'Title'}) %}
{% set eyebrow = eyebrow_editable.getData() %}
{% set title = title_editable.getData() %}
{% set no_radius = opendxp_checkbox('no_radius').isChecked() %}

{% set full_width = width == 'none' %}
{% set section_props = full_width ? {} : {container: width ?: 'default'} %}

{# Frontend media output only — in editmode the editables are rendered directly below, so keep
   this capture out of editmode to avoid rendering the same editable into a throwaway buffer. #}
{% set media %}
    {%- if not editmode -%}
        {%- if use_video and not video.isEmpty() -%}
            {{- video|raw -}}
        {%- elseif not image.isEmpty() -%}
            {{- image|raw -}}
        {%- endif -%}
    {%- endif -%}
{% endset %}
{% set has_media = media|trim is not empty %}
{% set has_body = style == 'card' or style == 'overlay' %}
{% set has_actions = editmode
    or not opendxp_link('link_primary').isEmpty()
    or not opendxp_link('link_secondary').isEmpty() %}

{% cui 'section' with section_props %}
    {% if editmode %}
        {# The dialog's "Media type" select decides which media editable is edited inline. #}
        {% if style == 'card' %}
            {# Preview the card layout so "Media beside body" (orient) and "Reverse order" are visible
               while editing: a cluster lays media beside the body, a stack keeps them column; the
               reverse toggle swaps the media to the end. No card chrome so editor UI is not clipped. #}
            {% set reverse = opendxp_checkbox('reverse').isChecked() %}
            <div class="{{ opendxp_checkbox('orient_row').isChecked() ? 'cui-cluster' : 'cui-stack' }}">
                {% if not reverse %}{%- if use_video -%}{{ video|raw }}{%- else -%}{{ image|raw }}{%- endif -%}{% endif %}
                <div class="cui-stack">
                    {{ opendxp_link('banner_link') }}
                    {{ eyebrow_editable|raw }}
                    {{ title_editable|raw }}
                    {{ opendxp_wysiwyg('body') }}
                    <div class="cui-cluster">
                        {% include '@CombatUIOpenDxp/areas/_partials/actions.html.twig' %}
                    </div>
                </div>
                {% if reverse %}{%- if use_video -%}{{ video|raw }}{%- else -%}{{ image|raw }}{%- endif -%}{% endif %}
            </div>
        {% else %}
            <div class="cui-stack">
                {%- if use_video -%}
                    {{- video|raw -}}
                {%- else -%}
                    {{- image|raw -}}
                {%- endif -%}
                {% if style == 'figure' %}
                    {{ caption_editable|raw }}
                {% endif %}
                {% if style == 'banner' %}
                    {{ opendxp_link('banner_link') }}
                    {{ eyebrow_editable|raw }}
                    {{ title_editable|raw }}
                {% endif %}
                {% if style == 'overlay' %}
                    {{ eyebrow_editable|raw }}
                    {{ title_editable|raw }}
                    {{ opendxp_wysiwyg('body') }}
                    <div class="cui-cluster">
                        {% include '@CombatUIOpenDxp/areas/_partials/actions.html.twig' %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
    {% elseif style == 'full' %}
        {% if has_media %}
            {% cui 'media-full' with {
                ratio: ratio,
                bleed: full_width,
                radius: no_radius ? 'none' : null,
            } %}
                {{- media|raw -}}
            {% endcui %}
        {% endif %}
    {% elseif style == 'banner' %}
        {# Banner: a linked media element with an optional eyebrow and heading below it. Unlike the
           card it brings no surface or padding — just the media (wrapped in the link) and, when set,
           a .cui-eyebrow and an h2.cui-display. Only the media carries the link, never the heading. #}
        {% set banner_link = opendxp_link('banner_link') %}
        {% set has_heading = eyebrow is not empty or title is not empty %}
        {% set media_block %}
            {%- if has_media -%}
                {%- set block -%}
                    {%- cui 'media-full' with {ratio: ratio, radius: no_radius ? 'none' : null} -%}
                        {{- media|raw -}}
                    {%- endcui -%}
                {%- endset -%}
                {%- if not banner_link.isEmpty() -%}
                    <a{{ cui_attrs({
                        href: banner_link.getHref(),
                        target: banner_link.getTarget() ?: null,
                        'aria-label': banner_link.getText() ?: title ?: null,
                    }) }}>{{ block|raw }}</a>
                {%- else -%}
                    {{- block|raw -}}
                {%- endif -%}
            {%- endif -%}
        {% endset %}
        {% if has_heading %}
            <div class="cui-stack">
                {{ media_block|raw }}
                {% if eyebrow is not empty %}<p class="cui-eyebrow">{{ eyebrow }}</p>{% endif %}
                {% if title is not empty %}<h2 class="cui-display">{{ title }}</h2>{% endif %}
            </div>
        {% else %}
            {{ media_block|raw }}
        {% endif %}
    {% elseif style == 'card' %}
        {% set card_style = opendxp_select('card_style').getData()|default('') %}
        {% set banner_link = opendxp_link('banner_link') %}
        {% set linked_media = not banner_link.isEmpty() and not use_video and not image.isEmpty() %}
        {% set card_props = {
            orient: opendxp_checkbox('orient_row').isChecked() ? 'row' : null,
            ratio: ratio,
            radius: no_radius ? 'none' : null,
            elevation: card_style == 'flat' ? 'flat' : null,
            variant: card_style == 'borderless' ? 'borderless' : null,
            media_position: opendxp_checkbox('reverse').isChecked() ? 'end' : null,
            eyebrow: eyebrow,
            title: title,
        }|filter(value => value is not empty) %}
        {% if linked_media %}
            {% set card_props = card_props|merge({
                image: image.getSrc(),
                image_alt: image.getAlt(),
                href: banner_link.getHref(),
            }) %}
            {% if banner_link.getText() %}
                {% set card_props = card_props|merge({media_label: banner_link.getText()}) %}
            {% endif %}
        {% endif %}
        {% cui 'media-card' with card_props %}
            {{ opendxp_wysiwyg('body') }}

            {% if has_media and not linked_media %}
                {% cui_slot 'media' %}{{ media|raw }}{% endcui_slot %}
            {% endif %}

            {% if has_actions %}
                {% cui_slot 'actions' %}
                    {% include '@CombatUIOpenDxp/areas/_partials/actions.html.twig' %}
                {% endcui_slot %}
            {% endif %}
        {% endcui %}
    {% elseif style == 'overlay' %}
        {% set overlay_props = {
            align: align,
            scrim: opendxp_select('scrim').getData(),
            ratio: ratio,
            radius: no_radius ? 'none' : null,
            eyebrow: eyebrow,
            title: title,
        }|filter(value => value is not empty) %}
        {% cui 'media-overlay' with overlay_props %}
            {{ opendxp_wysiwyg('body') }}

            {% if has_media %}
                {% cui_slot 'media' %}{{ media|raw }}{% endcui_slot %}
            {% endif %}

            {% if has_actions %}
                {% cui_slot 'actions' %}
                    {% include '@CombatUIOpenDxp/areas/_partials/actions.html.twig' %}
                {% endcui_slot %}
            {% endif %}
        {% endcui %}
    {% else %}
        {% if has_media %}
            {% set figure_props = {
                ratio: ratio,
                align: align == 'center' ? 'center' : null,
                radius: no_radius ? 'none' : null,
                bleed: full_width,
                caption: caption_editable.getData(),
            }|filter(value => value is not empty) %}
            {% cui 'figure' with figure_props %}
                <div class="cui-figure-media">{{ media|raw }}</div>
            {% endcui %}
        {% endif %}
    {% endif %}
{% endcui %}
