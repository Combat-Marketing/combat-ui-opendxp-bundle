{# Card-grid brick — block of @CombatUICore article cards in a grid, with an optional category filter. #}
{% set card_variant = opendxp_select('card_variant').getData()|default('') %}
{% set container = opendxp_select('container').getData()|default('') %}
{% set section_props = {
    spacing: opendxp_select('spacing').getData(),
    tone: opendxp_select('tone').getData(),
}|filter(value => value is not empty) %}
{% if container != 'none' %}
    {% set section_props = section_props|merge({container: container ?: 'default'}) %}
{% endif %}

{% set grid_props = {
    columns: opendxp_select('columns').getData(),
    gap: opendxp_select('gap').getData(),
    min: '18rem',
}|filter(value => value is not empty) %}

{% cui 'section' with section_props %}
    {% if editmode %}
        {% cui 'grid' with grid_props %}
            {% for i in opendxp_iterate_block(opendxp_block('cards')) %}
                {% set image = opendxp_image('image') %}
                {% set link = opendxp_link('link') %}
                <article class="cui-surface cui-article-card">
                    {% if card_variant != 'compact' %}
                        <div class="cui-article-card-media">{{ image|raw }}</div>
                    {% endif %}
                    <div class="cui-stack">
                        <p class="cui-eyebrow">{{ opendxp_input('category', {placeholder: 'Category'}) }}</p>
                        <h3 class="cui-display">{{ opendxp_input('title', {placeholder: 'Card title'}) }}</h3>
                        <p>{{ opendxp_textarea('text', {placeholder: 'Excerpt'}) }}</p>
                        {{ link|raw }}
                    </div>
                </article>
            {% endfor %}
        {% endcui %}
    {% else %}
        {% set show_filter = opendxp_checkbox('show_filter').isChecked() %}
        {% set categories = {} %}
        {% if show_filter %}
            {% for i in opendxp_iterate_block(opendxp_block('cards')) %}
                {% set category = opendxp_input('category').getData() %}
                {% if category %}
                    {% set categories = categories|merge({(category|lower): category}) %}
                {% endif %}
            {% endfor %}
        {% endif %}

        {% if show_filter and categories is not empty %}
            {% set grid_id = 'cui-card-grid-' ~ (info.index ?? 0) %}
            {% set grid_props = grid_props|merge({id: grid_id}) %}
            {% set chips = [] %}
            {% for value, label in categories %}
                {% set chips = chips|merge([{value: value, label: label}]) %}
            {% endfor %}
            {% set filter_props = {
                target: '#' ~ grid_id,
                categories: chips,
                label: opendxp_input('filter_label').getData(),
            }|filter(value => value is not empty) %}
            {% cui 'article-filter' with filter_props %}{% endcui %}
        {% endif %}

        {% cui 'grid' with grid_props %}
            {% for i in opendxp_iterate_block(opendxp_block('cards')) %}
                {% set image = opendxp_image('image') %}
                {% set link = opendxp_link('link') %}
                {% set category = opendxp_input('category').getData() %}
                {% set card_props = {
                    variant: card_variant,
                    title: opendxp_input('title').getData(),
                    href: link.isEmpty() ? null : link.getHref(),
                    category: category,
                    category_key: category ? category|lower : null,
                    excerpt: opendxp_textarea('text').getData(),
                }|filter(value => value is not empty) %}
                {% if card_variant != 'compact' and not image.isEmpty() %}
                    {% set card_props = card_props|merge({image: image.getSrc(), image_alt: image.getAlt()}) %}
                {% endif %}
                {% cui 'article-card' with card_props %}
                    {% if not link.isEmpty() and link.getText() %}
                        {% cui_slot 'actions' %}
                            <a class="cui-button" href="{{ link.getHref() }}"{% if link.getTarget() %} target="{{ link.getTarget() }}"{% endif %}>{{ link.getText() }}</a>
                        {% endcui_slot %}
                    {% endif %}
                {% endcui %}
            {% endfor %}
        {% endcui %}
    {% endif %}
{% endcui %}
